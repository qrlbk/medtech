# ---- Database ----
POSTGRES_USER=medprice
POSTGRES_PASSWORD=medprice
POSTGRES_DB=medprice
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://medprice:medprice@postgres:5432/medprice

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Meilisearch ----
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=masterKey_change_me

# ---- Backend ----
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change_me_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000

# ---- Parsing mode ----
# 1 = parsers read bundled fixtures (deterministic demo data, no network).
# Lets "Запустить парсинг" in the admin populate the DB instantly.
# Set to 0 for live parsing of real sources.
MEDPRICE_OFFLINE=1
# Set to 0 to skip TLS verification fallback for sites with broken cert chains.
MEDPRICE_TLS_VERIFY=1

# ---- Geo enrichment (2GIS / Google Maps, ТЗ) ----
# Clinic address / working hours / coordinates. Without a key the app falls
# back to the bundled clinics.json seed.
DGIS_API_KEY=
GOOGLE_MAPS_API_KEY=

# ---- Normalization / Embeddings ----
# Semantic matching is optional. Two providers:
#   EMBEDDING_PROVIDER=local  -> sentence-transformers (offline, free, needs the
#                                ML extras from requirements-ml.txt; ~1GB torch).
#                                Use EMBEDDING_DIM=384.
#   EMBEDDING_PROVIDER=openai -> OpenAI embeddings API (no torch, needs
#                                OPENAI_API_KEY below). Use EMBEDDING_DIM=1536.
# Leave EMBEDDINGS_ENABLED=false to skip semantics (matcher uses exact + fuzzy,
# plus the LLM selector if enabled).
EMBEDDINGS_ENABLED=false
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
EMBEDDING_DIM=384
# Semantic auto-accept threshold (cosine similarity). Local MiniLM ~0.78 works;
# OpenAI embeddings score lower, so try ~0.5 there. Below this, candidates still
# go to the LLM selector, so being conservative is safe.
NORMALIZE_MATCH_THRESHOLD=0.78
NORMALIZE_FUZZY_THRESHOLD=88

# ---- Data freshness (per TЗ) ----
DATA_FRESH_DAYS=30
RAW_RETENTION_DAYS=90

# ---- LLM selector (optional) ----
# Final normalization stage: when exact/fuzzy/semantic are not confident, the
# LLM picks the best catalog entry from the top-K shortlist (or "none").
# Requires an OpenAI key. Cheap for batch normalization (gpt-4o-mini).
LLM_ENABLED=false
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_CANDIDATE_K=5

# ---- Telegram bot (optional) ----
TELEGRAM_BOT_TOKEN=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
